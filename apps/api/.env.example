NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://tutor:tutor_dev_password@localhost:5433/tutor_app
REDIS_URL=redis://localhost:6380
SESSION_COOKIE_SECRET=dev_only_change_me_in_prod_at_least_32_chars
MAILER=console
WEB_ORIGIN=http://localhost:5174
# PUBLIC_API_BASE_URL is the base used to construct user-facing links (magic
# link consume URL). Point at the Vite dev proxy in development so cookies
# set by /auth/consume land on the web origin (not the api origin).
PUBLIC_API_BASE_URL=http://localhost:5174/api
# Phase 3 — Google Calendar integration. All four are optional in dev so the
# api boots without a real Google project; required as a group if any one is
# set. Get the client id/secret from a Google Cloud project with the Calendar
# API enabled; the redirect URI must match what's configured there.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Uncomment when filling in CLIENT_ID/SECRET above — the validator requires
# all three to be set together (any one alone makes the api refuse to boot).
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5174/api/integrations/google/callback
# 32-byte hex (use `openssl rand -hex 32`). Encrypts Google refresh tokens at
# rest. Required whenever any Google env above is set.
INTEGRATION_TOKEN_ENCRYPTION_KEY=
# Phase 5 — Whisper voice transcription. Optional in dev (the api boots with
# a FakeTranscriberClient that returns canned text). Required in production.
# OPENAI_API_KEY=
# Local-filesystem dir for raw audio uploads while transcription is pending.
# Files are deleted post-transcription. In prod, point at a Railway Volume.
STORAGE_DIR=./var/audio
# WHISPER_MAX_RETRIES=3
# WHISPER_BREAKER_THRESHOLD=5
# WHISPER_BREAKER_RESET_MS=60000
# WHISPER_CONCURRENCY=2
# Phase 12 — adaptive game engine. All optional (defaults shown). Cross-play
# difficulty: a play's accuracy over its non-review slots drives the NEXT
# play's level. Advance at/above ADVANCE_THRESHOLD; never auto-advance below
# HOLD_FLOOR; after NUDGE_EVERY_N competent holds nudge up; require MIN_SAMPLE
# answered non-review questions before any change; LEVEL_ALLOW_DOWN steps down
# on very-low-accuracy plays (off by default).
# LEVEL_ADVANCE_THRESHOLD=0.8
# LEVEL_HOLD_FLOOR=0.5
# LEVEL_NUDGE_EVERY_N=3
# LEVEL_MIN_SAMPLE=3
# LEVEL_ALLOW_DOWN=false
# Spaced repetition (Leitner): per-box review intervals in DAYS (index = box-1,
# boxes 1..5); REVIEW_FRACTION reserves part of each session for due reviews.
# SR_BOX_INTERVALS_DAYS=0,1,3,7,16
# REVIEW_FRACTION=0.3
# Background bank top-up: per-tutor monthly cap SEPARATE from the manual
# GAME_GEN_MONTHLY_CAP; questions per batch; min gap between a game's top-ups.
# GAME_GEN_TOPUP_MONTHLY_CAP=50
# TOPUP_BATCH_SIZE=20
# TOPUP_COOLDOWN_MS=21600000
