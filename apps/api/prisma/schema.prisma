generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Phase 1 — auth, sessions, audit
// ---------------------------------------------------------------------------

model Tutor {
  id                         String    @id @default(cuid())
  email                      String    @unique
  name                       String?
  locale                     String    @default("en") // en | pt | he — UI direction
  // Phase 11: what the tutor teaches (free text, e.g. "Portuguese", "Math").
  // Shown to the LLM as context so it generates subject-appropriate
  // questions, not just questions in the tutor's UI locale.
  subject                    String?
  // Phase 11: the language the LESSONS are in (== output language for game
  // generation). A Hebrew-speaking Portuguese tutor has locale=he but
  // teachingLanguage=pt. Distinct from `locale` (UI) so a tutor can write
  // Hebrew feedback about a Portuguese lesson and still get Portuguese
  // questions.
  teachingLanguage           String?
  monthlyGenerations         Int       @default(0)
  monthlyGenerationsResetAt  DateTime  @default(now())
  // Phase 9: separate Whisper minute cap; incremented in Phase 5 when
  // audio jobs finish. Kept distinct from `monthlyGenerations` because
  // Whisper + Anthropic have different cost profiles and per-tutor caps.
  monthlyWhisperMinutes      Int       @default(0)
  monthlyWhisperResetAt      DateTime  @default(now())
  // Filled in Phase 3.
  googleRefreshToken         String?
  lessonCalendarIds          String[]  @default([])
  deletedAt                  DateTime? // soft delete; cron purges after grace
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  sessions Session[]
  students Student[]

  @@index([deletedAt])
}

model MagicLink {
  token      String    @id
  email      String
  expiresAt  DateTime
  consumedAt DateTime?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())

  @@index([email, createdAt])
  @@index([expiresAt])
}

model Session {
  token     String   @id
  tutorId   String
  expiresAt DateTime
  createdAt DateTime @default(now())
  ipAddress String?
  userAgent String?

  tutor Tutor @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  @@index([tutorId])
  @@index([expiresAt])
}

model AuditLog {
  id         String    @id @default(cuid())
  tutorId    String?
  actorType  ActorType
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())

  @@index([tutorId, createdAt])
  @@index([entityType, entityId])
}

enum ActorType {
  TUTOR
  STUDENT
  SYSTEM
}

// ---------------------------------------------------------------------------
// Phase 2+ — students, lessons, games, attempts. Defined upfront so later
// migrations are additive only.
// ---------------------------------------------------------------------------

model Student {
  id                  String    @id @default(cuid())
  tutorId             String
  name                String
  shareToken          String    @unique
  shareTokenRotatedAt DateTime  @default(now())
  notes               String?
  // Phase 11: student's L1 (e.g. "he", "pt", "en"). Passed to the LLM as
  // context so generated questions can frame instructions / accept
  // alternates in the student's native language when helpful.
  nativeLanguage      String?
  deletedAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tutor    Tutor     @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  lessons  Lesson[]
  attempts Attempt[]
  gameProgress StudentGameProgress[]

  @@index([tutorId])
  @@index([deletedAt])
}

enum LessonSource {
  GOOGLE_CALENDAR
  MANUAL
}

enum FeedbackSource {
  TEXT
  VOICE
}

// Phase 5: lifecycle of the Whisper transcription for a lesson's audio
// upload. Distinct from FeedbackSource (which records how the saved
// feedback was produced) because a lesson can be in TRANSCRIBING while
// its final feedbackText hasn't been confirmed yet.
enum TranscriptionStatus {
  NONE
  PENDING
  TRANSCRIBING
  DONE
  FAILED
}

model Lesson {
  id                   String              @id @default(cuid())
  studentId            String
  googleEventId        String?
  source               LessonSource        @default(MANUAL)
  title                String?
  occurredAt           DateTime
  feedbackText         String?
  feedbackSource       FeedbackSource      @default(TEXT)
  // Phase 5: storage-relative path to the uploaded audio while
  // transcription is pending; NULL after Whisper succeeds (audio is
  // deleted post-transcription per spec).
  audioUrl             String?
  transcriptionStatus  TranscriptionStatus @default(NONE)
  // Tutor-safe error message (no stack traces) populated only when the
  // job hits terminal FAILED. Cleared on retry.
  transcriptionError   String?
  deletedAt            DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  games   Game[]

  @@index([studentId, occurredAt])
  @@index([deletedAt])
  @@index([transcriptionStatus])
}

enum GameType {
  FILL_BLANK
  TIMED_QUIZ
}

enum GameStatus {
  DRAFT
  ASSIGNED
  ARCHIVED
  GENERATING
  FAILED
}

model Game {
  id                   String     @id @default(cuid())
  lessonId             String
  type                 GameType
  title                String
  status               GameStatus @default(DRAFT)
  questionPool         Json
  poolSize             Int
  generationPromptHash String?
  locale               String     @default("en")
  // Phase 4: human-readable reason a FAILED job set, so the tutor sees more
  // than just "failed" in the UI. Kept short + tutor-safe (no stack traces).
  generationError      String?
  deletedAt            DateTime?
  assignedAt           DateTime?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  lesson   Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  attempts Attempt[]
  studentProgress StudentGameProgress[]

  @@index([lessonId])
  @@index([status])
  @@index([deletedAt])
}

model Attempt {
  id              String    @id @default(cuid())
  gameId          String
  studentId       String
  startedAt       DateTime
  finishedAt      DateTime?
  score           Int       @default(0)
  livesLost       Int       @default(0)
  questionResults Json      @default("[]")
  createdAt       DateTime  @default(now())

  game    Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([gameId, studentId])
  @@index([studentId, startedAt])
}

// ---------------------------------------------------------------------------
// Phase 12 — adaptive game engine: per-(student, game) cross-play state
// ---------------------------------------------------------------------------

// One mutable singleton row per (student, game). Drives difficulty escalation
// across plays and non-repetition. Read before an attempt is sampled, written
// once on the finishedAt:null→now transition (abandoned-cron finishes do NOT
// write here). seenQuestionIds is the authoritative "answered before" set; the
// selector treats it as a membership Set so duplicate pushes are harmless.
model StudentGameProgress {
  studentId       String
  gameId          String
  currentLevel    Int       @default(1) // 1..5 — target difficulty for the next play
  playsCompleted  Int       @default(0)
  nudgeCounter    Int       @default(0) // consecutive competent holds without advancing
  seenQuestionIds String[]  @default([])
  lastAccuracy    Float?
  lastLevelDelta  Int       @default(0)
  lastPlayedAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  game    Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@id([studentId, gameId])
  @@index([gameId])
}

// ---------------------------------------------------------------------------
// Phase 3 — Google OAuth CSRF state
// ---------------------------------------------------------------------------

// One-time-use state values for the Google OAuth handshake. The /connect
// endpoint stores a random state keyed to the issuing tutor; /callback
// verifies it and consumes the row. Rows are pruned on consume + a TTL
// sweep can drop expired-and-unused rows.
model OAuthState {
  state      String   @id // random URL-safe token, 32 bytes base64url
  tutorId    String
  provider   String   @default("google")
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([tutorId])
  @@index([expiresAt])
}
